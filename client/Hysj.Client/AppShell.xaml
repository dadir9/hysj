<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="Hysj.Client.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Hysj.Client.Views"
       Shell.FlyoutBehavior="Disabled"
       BackgroundColor="{StaticResource PrimaryBg}">

    <!-- Initial page: overridden in App.xaml.cs based on auth state -->
    <ShellContent Route="LanguagePage"
                  ContentTemplate="{DataTemplate views:LanguageSelectionPage}"/>

    <ShellContent Route="LoginPage"
                  ContentTemplate="{DataTemplate views:LoginPage}"/>

    <ShellContent Route="RegisterPage"
                  ContentTemplate="{DataTemplate views:RegisterPage}"/>

    <ShellContent Route="ConversationListPage"
                  ContentTemplate="{DataTemplate views:ConversationListPage}"/>

</Shell>
