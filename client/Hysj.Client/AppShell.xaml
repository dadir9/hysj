<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="Hysj.Client.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Hysj.Client.Views"
       Shell.FlyoutBehavior="Disabled"
       BackgroundColor="{StaticResource PrimaryBg}">

    <!-- Language selection (shown on first run) -->
    <ShellContent Route="LanguagePage"
                  ContentTemplate="{DataTemplate views:LanguageSelectionPage}"
                  Shell.FlyoutItemIsVisible="False" />

    <!-- Login -->
    <ShellContent Route="LoginPage"
                  Shell.FlyoutItemIsVisible="False" />

</Shell>
