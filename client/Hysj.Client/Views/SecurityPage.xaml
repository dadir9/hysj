<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Hysj.Client.ViewModels"
             xmlns:models="clr-namespace:Hysj.Client.Models"
             xmlns:svc="clr-namespace:Hysj.Client.Services"
             x:Class="Hysj.Client.Views.SecurityPage"
             x:DataType="vm:SecurityViewModel"
             BackgroundColor="{StaticResource PrimaryBg}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,52,20,32" Spacing="0">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,28">
                <Button Grid.Column="0" Text="←"
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource PurpleAccent}"
                        FontSize="22" Padding="0,0,12,0"/>
                <Label Grid.Column="1" Text="Security"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
            </Grid>

            <!-- Encryption status -->
            <Label Text="Encryption layers" FontSize="13" FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,10"/>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16" Margin="0,0,0,20">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🔄" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Double Ratchet" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Forward secrecy per message"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="✓" FontSize="16"
                               TextColor="{StaticResource ShieldGreen}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="⚛" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Post-Quantum Hybrid" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="ECC + Kyber lattice cryptography"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="✓" FontSize="16"
                               TextColor="{StaticResource QuantumBlue}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🕵" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Sealed Sender" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Server never knows who you are"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="✓" FontSize="16"
                               TextColor="{StaticResource SealedTeal}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="🧅" FontSize="18"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Onion Routing" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="3-hop layered encryption"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="✓" FontSize="16"
                               TextColor="{StaticResource OnionPurple}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Relay nodes -->
            <Label Text="Relay nodes" FontSize="13" FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,10"/>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16" Margin="0,0,0,20">
                <CollectionView ItemsSource="{Binding RelayNodes}">
                    <CollectionView.EmptyView>
                        <Label Text="No relay nodes available"
                               TextColor="{StaticResource TextTertiary}" FontSize="13"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="svc:RelayNodeDto">
                            <Grid ColumnDefinitions="Auto,*" Padding="0,6" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="●"
                                       TextColor="{StaticResource ShieldGreen}" FontSize="10"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding Address}"
                                       TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <!-- Devices -->
            <Label Text="Your devices" FontSize="13" FontAttributes="Bold"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,10"/>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16" Margin="0,0,0,28">
                <CollectionView ItemsSource="{Binding Devices}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:DeviceInfo">
                            <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding DeviceName}"
                                           FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                                    <Label Text="{Binding LastActiveAt, StringFormat='Last active: {0:MMM d}'}"
                                           FontSize="12" TextColor="{StaticResource TextTertiary}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Remove"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SecurityViewModel}}, Path=RemoveDeviceCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource DangerRed}"
                                        FontSize="13"
                                        IsVisible="{Binding IsCurrent, Converter={StaticResource InvertedBoolConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <!-- Danger zone -->
            <Label Text="Danger zone" FontSize="13" FontAttributes="Bold"
                   TextColor="{StaticResource DangerRed}" Margin="4,0,0,10"/>

            <Frame BackgroundColor="{StaticResource TertiaryBg}"
                   BorderColor="{StaticResource DangerRed}" CornerRadius="12"
                   Padding="16" Margin="0,0,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Emergency Wipe" FontSize="15" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label Text="Immediately delete all messages, keys, and sessions on all your devices. This cannot be undone."
                           TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                    <Button Text="Wipe Everything"
                            Command="{Binding WipeAllCommand}"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White" CornerRadius="10"
                            HeightRequest="44" Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
