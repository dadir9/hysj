<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Hysj.Client.ViewModels"
             x:Class="Hysj.Client.Views.CreateGroupPage"
             x:DataType="vm:CreateGroupViewModel"
             BackgroundColor="{StaticResource PrimaryBg}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,52,24,32" Spacing="0">

            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,32">
                <Button Grid.Column="0" Text="←"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource PurpleAccent}"
                        FontSize="22" Padding="0,0,12,0"/>
                <Label Grid.Column="1" Text="New Group"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Group name -->
            <Label Text="Group name" FontSize="13"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,8"/>
            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16,4" Margin="0,0,0,24">
                <Entry Placeholder="Enter group name"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       Text="{Binding GroupName}"/>
            </Frame>

            <!-- Group type -->
            <Label Text="Group type" FontSize="13"
                   TextColor="{StaticResource TextSecondary}" Margin="4,0,0,8"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,8">
                <!-- Normal -->
                <Frame Grid.Column="0"
                       BackgroundColor="{Binding IsAnonymous, Converter={StaticResource InvertedBoolToColorConverter}}"
                       BorderColor="{StaticResource Border}" CornerRadius="12"
                       Padding="16,12" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateGroupViewModel}}, Path=CancelCommand}"
                                              CommandParameter="false"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="👥" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Normal" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
                        <Label Text="Members see each other" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Anonymous -->
                <Frame Grid.Column="1"
                       BackgroundColor="{Binding IsAnonymous, Converter={StaticResource BoolToColorConverter}}"
                       BorderColor="{StaticResource OnionPurple}" CornerRadius="12"
                       Padding="16,12" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAnonymousSelected"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🎭" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Anonymous" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
                        <Label Text="Random alias for each member" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Anonymous warning -->
            <Frame BackgroundColor="{StaticResource TertiaryBg}"
                   BorderColor="{StaticResource OnionPurple}" CornerRadius="10"
                   Padding="14,10" Margin="0,0,0,24"
                   IsVisible="{Binding IsAnonymous}">
                <Label Text="⚠ Group type cannot be changed after creation"
                       TextColor="{StaticResource OnionPurple}" FontSize="12"/>
            </Frame>

            <!-- Members can add toggle -->
            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16,12" Margin="0,0,0,32">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Members can add others"
                               TextColor="{StaticResource TextPrimary}" FontSize="14"/>
                        <Label Text="Allow all members to invite new people"
                               TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding MembersCanAdd}"
                            OnColor="{StaticResource PurpleAccent}"
                            VerticalOptions="Center"/>
                </Grid>
            </Frame>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13" Margin="4,0,0,12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"/>

            <Button Text="Create Group"
                    Command="{Binding CreateCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="{StaticResource PurpleAccent}"
                    TextColor="White" CornerRadius="12"
                    HeightRequest="52" FontSize="16" FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
