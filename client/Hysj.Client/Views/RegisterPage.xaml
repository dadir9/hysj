<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Hysj.Client.ViewModels"
             x:Class="Hysj.Client.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="{StaticResource PrimaryBg}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <Label Text="Create Account"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0,0,0,8"/>
            <Label Text="All messages are end-to-end encrypted"
                   FontSize="13" TextColor="{StaticResource TextSecondary}"
                   Margin="0,0,0,40"/>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16,4" Margin="0,0,0,12">
                <Entry Placeholder="Username"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       Text="{Binding Username}"/>
            </Frame>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16,4" Margin="0,0,0,12">
                <Entry Placeholder="Password"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Text="{Binding Password}"/>
            </Frame>

            <Frame BackgroundColor="{StaticResource SecondaryBg}"
                   BorderColor="{StaticResource Border}" CornerRadius="12"
                   Padding="16,4" Margin="0,0,0,12">
                <Entry Placeholder="Confirm password"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       Text="{Binding ConfirmPass}"/>
            </Frame>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource DangerRed}"
                   FontSize="13" Margin="4,0,0,12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"/>

            <!-- TOTP QR shown after register -->
            <VerticalStackLayout IsVisible="{Binding ShowQr}" Spacing="12" Margin="0,0,0,20">
                <Frame BackgroundColor="{StaticResource TertiaryBg}"
                       BorderColor="{StaticResource ShieldGreen}" CornerRadius="12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="⚠ Save your 2FA key" FontAttributes="Bold"
                               TextColor="{StaticResource ShieldGreen}" FontSize="15"/>
                        <Label Text="Scan this in your authenticator app:"
                               TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        <Label Text="{Binding TotpSecret}"
                               TextColor="{StaticResource TextPrimary}" FontSize="12"
                               FontFamily="OpenSansRegular"/>
                        <Button Text="Go to Login"
                                Command="{Binding GoToLoginCommand}"
                                BackgroundColor="{StaticResource ShieldGreen}"
                                TextColor="White" CornerRadius="10" HeightRequest="44"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <Button Text="Create Account"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    IsVisible="{Binding ShowQr, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="{StaticResource PurpleAccent}"
                    TextColor="White" CornerRadius="12"
                    HeightRequest="52" FontSize="16" FontAttributes="Bold"
                    Margin="0,4,0,24"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4"
                                   IsVisible="{Binding ShowQr, Converter={StaticResource InvertedBoolConverter}}">
                <Label Text="Already have an account?"
                       TextColor="{StaticResource TextSecondary}" FontSize="14"/>
                <Label Text="Sign in"
                       TextColor="{StaticResource PurpleAccent}" FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
